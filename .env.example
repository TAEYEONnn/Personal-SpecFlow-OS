NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# AI provider: nvidia | openai
AI_PROVIDER=nvidia
# NVIDIA Build
NVIDIA_API_KEY=
NVIDIA_MODEL=mistralai/mistral-medium-3.5-128b
NVIDIA_REASONING_EFFORT=none
NVIDIA_STRUCTURED_MODE=prompt
# OpenAI fallback
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
# AI execution
AI_COMPILE_CONCURRENCY=1
AI_TIMEOUT_MS=90000
# Notion OAuth (optional — needed for "Export to Notion")
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
